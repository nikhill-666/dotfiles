@define-color bg #010E12;
@define-color fg #b0b9bc;
@define-color gray1 #3ea5c5;
@define-color gray2 #6b858e;
@define-color gray3 #4394f4;
@define-color gray4 #bdbd89;
@define-color gray5 #1e748f;
@define-color fg_bright #b0b9bc;

window {
    background-color: @bg;
    border: 2px solid @gray3;
}

input {
    background-color: @bg;
    color: @fg;
    border: 1px solid @gray2;
}

input:selected {
    background-color: @gray1;
    color: @fg_bright;
}

#entry {
    color: @fg;
    background-color: @bg;
    padding: 5px;
    margin: 2px;
}

#entry:selected {
    background-color: @gray1;
    color: @fg_bright;
}

scrollbar {
    background-color: @bg;
}

scrollbar slider {
    background-color: @gray2;
    border-radius: 5px;
}

scrollbar slider:hover {
    background-color: @gray3;
}