# Mako Notification Daemon Configuration
# Aether theme colors with custom styling

# Colors (from Aether theme)
text-color=#dbdbdb
background-color=#000000dd
border-size=0
border-radius=10

# Note: text-color will be updated by reload-aether-theme to match foreground from colors.toml

# Layout
width=420
height=110
padding=10
font=Liberation Sans 11
anchor=top-right
outer-margin=20
default-timeout=5000
max-icon-size=32

# Spacing
margin=20

# App-specific rules
[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false
